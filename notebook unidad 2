        "---\n",
        "# PUNTO 2. Métricas de desempeño (Train + Validation)"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "0W20DhYBR2HE",
        "outputId": "d06aa0ef-13df-48e9-e501-88098a3272b6"
      },
      "source": [
        "from sklearn.metrics import (accuracy_score, precision_score, recall_score,\n",
        "                             f1_score, roc_auc_score, classification_report)\n",
        "from scipy.stats import ks_2samp\n",
        "\n",
        "def evaluar(modelo, X_tr, y_tr, X_v, y_v, nombre):\n",
        "    yp_tr = modelo.predict(X_tr)\n",
        "    yp_v = modelo.predict(X_v)\n",
        "    yprob_v = modelo.predict_proba(X_v)[:, 1]\n",
        "    pos = yprob_v[y_v == 1]\n",
        "    neg = yprob_v[y_v == 0]\n",
        "    ks, _ = ks_2samp(pos, neg)\n",
        "    return {\n",
        "        'Modelo': nombre,\n",
        "        'Accuracy_Train': accuracy_score(y_tr, yp_tr),\n",
        "        'Accuracy_Val': accuracy_score(y_v, yp_v),\n",
        "        'Precision_Val': precision_score(y_v, yp_v),\n",
        "        'Recall_Val': recall_score(y_v, yp_v),\n",
        "        'F1_Val': f1_score(y_v, yp_v),\n",
        "        'AUC_Val': roc_auc_score(y_v, yprob_v),\n",
        "        'KS_Val': ks,\n",
        "    }\n",
        "\n",
        "modelos = [\n",
        "    (l1_clf, 'L1 (Lasso)'),\n",
        "    (l2_clf, 'L2 (Ridge)'),\n",
        "    (en_clf, 'ElasticNet'),\n",
        "    (rf_clf, 'Random Forest'),\n",
        "    (xgb_clf, 'XGBoost'),\n",
        "    (mlp_clf, 'Red Neuronal'),\n",
        "]\n",
        "\n",
        "resultados = [evaluar(m, X_train, y_train, X_val, y_val, n) for m, n in modelos]\n",
        "df_resultados = pd.DataFrame(resultados)\n",
        "print(df_resultados.to_string(index=False, float_format='%.4f'))"
      ],
      "execution_count": 9,
