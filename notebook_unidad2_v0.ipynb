      "source": [
        "# Curva ROC y Matriz de Confusión\n",
        "fpr, tpr, _ = roc_curve(y_test, y_proba_test)\n",
        "auc_test = roc_auc_score(y_test, y_proba_test)\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "\n",
        "axes[0].plot(fpr, tpr, color='steelblue', lw=2, label=f'AUC = {auc_test:.4f}')\n",
        "axes[0].plot([0, 1], [0, 1], 'r--', lw=1)\n",
        "axes[0].set_xlabel('FPR')\n",
        "axes[0].set_ylabel('TPR')\n",
        "axes[0].set_title(f'Curva ROC - {mejor_nombre}')\n",
        "axes[0].legend()\n",
        "axes[0].grid(alpha=0.3)\n",
        "\n",
        "cm = confusion_matrix(y_test, y_pred_test)\n",
        "sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[1],\n",
        "            xticklabels=['Bajo', 'Alto'], yticklabels=['Bajo', 'Alto'])\n",
        "axes[1].set_xlabel('Predicción')\n",
        "axes[1].set_ylabel('Real')\n",
        "axes[1].set_title('Matriz de Confusión')\n",
        "\n",
        "plt.tight_layout()\n",
