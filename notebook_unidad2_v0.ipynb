      "cell_type": "markdown",
      "metadata": {
        "id": "mu0V6So3R2HE"
      },
      "source": [
        "---\n",
        "# PUNTO 3. Optimización de hiperparámetros\n",
        "\n",
        "**Método:** GridSearchCV realiza una búsqueda exhaustiva de todas las combinaciones de hiperparámetros. Para cada combinación entrena el modelo con validación cruzada (5-fold) y selecciona la que maximiza la métrica (AUC en este caso)."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "LvVspCFMR2HE",
        "outputId": "d80f055e-5f6c-495b-96c5-429c7dd96c4c"
      },
      "source": [
        "from sklearn.model_selection import GridSearchCV\n",
        "\n",
        "# Optimizar XGBoost (mejor candidato típico)\n",
        "param_grid = {\n",
        "    'n_estimators': [100, 200, 300],\n",
        "    'max_depth': [3, 5, 7],\n",
        "    'learning_rate': [0.01, 0.05, 0.1],\n",
        "    'subsample': [0.8, 1.0],\n",
        "}\n",
        "\n",
        "grid = GridSearchCV(\n",
        "    XGBClassifier(random_state=42, verbosity=0),\n",
        "    param_grid, cv=5, scoring='roc_auc', n_jobs=-1, verbose=1\n",
        ")\n",
        "grid.fit(X_train, y_train)\n",
        "\n",
        "print(f\"Mejores hiperparámetros: {grid.best_params_}\")\n",
        "print(f\"Mejor AUC (CV): {grid.best_score_:.4f}\")"
      ],
      "execution_count": 11,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Fitting 5 folds for each of 54 candidates, totalling 270 fits\n",
            "Mejores hiperparámetros: {'learning_rate': 0.05, 'max_depth': 7, 'n_estimators': 300, 'subsample': 0.8}\n",
            "Mejor AUC (CV): 0.9641\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "mzSlQPcXR2HF",
        "outputId": "08b10688-45cf-4356-f98d-9bad7ad4e477"
      },
      "source": [
        "# Evaluar modelo optimizado\n",
        "xgb_opt = grid.best_estimator_\n",
        "res_opt = evaluar(xgb_opt, X_train, y_train, X_val, y_val, 'XGBoost Optimizado')\n",
        "\n",
        "# Comparación antes vs después\n",
        "xgb_orig = resultados[4]\n",
        "print(f\"{'Modelo':<25} {'Accuracy':>10} {'AUC':>10} {'F1':>10}\")\n",
        "print(\"-\" * 56)\n",
        "print(f\"{'XGBoost Original':<25} {xgb_orig['Accuracy_Val']:>10.4f} {xgb_orig['AUC_Val']:>10.4f} {xgb_orig['F1_Val']:>10.4f}\")\n",
        "print(f\"{'XGBoost Optimizado':<25} {res_opt['Accuracy_Val']:>10.4f} {res_opt['AUC_Val']:>10.4f} {res_opt['F1_Val']:>10.4f}\")"
      ],
      "execution_count": 12,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Modelo                      Accuracy        AUC         F1\n",
            "--------------------------------------------------------\n",
            "XGBoost Original              0.8980     0.9654     0.8984\n",
            "XGBoost Optimizado            0.9025     0.9660     0.9032\n"
          ]
        }
      ]
    },
