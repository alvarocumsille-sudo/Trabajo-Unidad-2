      "source": [
        "**Justificación de la métrica principal:**\n",
        "- **AUC** es la métrica principal porque es robusta ante desbalance de clases y mide la capacidad discriminativa del modelo independiente del umbral.\n",
        "- **F1-Score** complementa balanceando Precision y Recall."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "IOgzExAJR2HF",
        "outputId": "b7388a7c-7e85-4f2c-deb1-8521c3f0514d"
      },
      "source": [
        "# Selección del modelo final (mayor AUC en validación)\n",
        "mejor_idx = todos['AUC_Val'].idxmax()\n",
        "mejor_nombre = todos.loc[mejor_idx, 'Modelo']\n",
        "print(f\"Modelo final: {mejor_nombre}\")\n",
        "print(f\"AUC Validación: {todos.loc[mejor_idx, 'AUC_Val']:.4f}\")\n",
        "\n",
        "# Seleccionar objeto modelo\n",
        "if 'Optimizado' in mejor_nombre:\n",
        "    modelo_final = xgb_opt\n",
        "elif 'XGBoost' in mejor_nombre:\n",
        "    modelo_final = xgb_clf\n",
        "elif 'Random Forest' in mejor_nombre:\n",
        "    modelo_final = rf_clf\n",
        "elif 'Red Neuronal' in mejor_nombre:\n",
        "    modelo_final = mlp_clf\n",
        "elif 'L1' in mejor_nombre:\n",
        "    modelo_final = l1_clf\n",
        "elif 'L2' in mejor_nombre:\n",
        "    modelo_final = l2_clf\n",
        "else:\n",
        "    modelo_final = en_clf"
      ],
      "execution_count": 14,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Modelo final: XGBoost Optimizado\n",
            "AUC Validación: 0.9660\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "R069lbnSR2HF",
        "outputId": "6fb724df-5011-4284-cb8a-8849ca8fd740"
      },
      "source": [
        "# Evaluación en TEST (una sola vez)\n",
        "from sklearn.metrics import roc_curve, confusion_matrix\n",
        "\n",
        "y_pred_test = modelo_final.predict(X_test)\n",
        "y_proba_test = modelo_final.predict_proba(X_test)[:, 1]\n",
        "\n",
        "print(\"=\" * 50)\n",
        "print(\"RESULTADO FINAL EN TEST\")\n",
        "print(\"=\" * 50)\n",
        "print(f\"Modelo: {mejor_nombre}\")\n",
        "print(f\"Accuracy: {accuracy_score(y_test, y_pred_test):.4f}\")\n",
        "print(f\"AUC:      {roc_auc_score(y_test, y_proba_test):.4f}\")\n",
        "print(f\"F1:       {f1_score(y_test, y_pred_test):.4f}\")\n",
        "print(f\"\\nReporte:\")\n",
        "print(classification_report(y_test, y_pred_test, target_names=['Bajo', 'Alto']))"
      ],
